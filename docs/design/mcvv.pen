                {
                  "type": "text",
                  "id": "MOGEQ",
                  "name": "H2",
                  "fill": "$white",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Není to běh. Je to výzva.",
                  "lineHeight": 1.02,
                  "fontFamily": "$font-display",
                  "fontSize": 54,
                  "fontWeight": "700",
                  "letterSpacing": -0.5
                },
                {
                  "type": "text",
                  "id": "pWqJE",
                  "name": "P1",
                  "fill": "$off-white",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Malá cena Velké Verandy je tradiční lesní kros v srdci chocenských lesů. Na pouhých 4300 metrech tě čeká vše, co dělá terénní běh nezapomenutelným — strmé výběhy, technické seběhy a kořeny pod nohama.",
                  "lineHeight": 1.6,
                  "fontFamily": "$font-body",
                  "fontSize": 17,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "OOhjd",
                  "name": "P2",
                  "fill": "$text-muted",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Krátká vzdálenost svádí k podcenění. Profil tratě tě ale rychle vyvede z omylu. Je to závod o charakteru — pro hobby běžce i ostřílené borce.",
                  "lineHeight": 1.6,
