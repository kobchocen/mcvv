DATABASE_URL="mysql://mcvv:mcvv@localhost:3306/mcvv"

# Dedicated shadow database for `prisma migrate dev` (MySQL/MariaDB strictly requires
# a *different* database than the main one).
# Create it + grant rights with the one-time command documented in compose.dev.yaml.
# See: https://pris.ly/d/migrate-shadow
SHADOW_DATABASE_URL="mysql://mcvv:mcvv@localhost:3306/mcvv_shadow"

TIME_ZONE="Europe/Prague"
